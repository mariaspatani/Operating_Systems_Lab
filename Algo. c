#include<stdio.h>
#include<stdlib.h>
#include<time.h>

int main()
{
    int n, frames, choice;
    int ref[50];
    
    printf("Enter length of reference string: ");
    scanf("%d",&n);

    printf("Enter number of frames (1-7): ");
    scanf("%d",&frames);

    srand(time(0));

    printf("\nReference String:\n");
    for(int i=0;i<n;i++)
    {
        ref[i] = rand()%10;
        printf("%d ",ref[i]);
    }

    printf("\n\n1. FIFO\n2. LRU\n3. Optimal\n");
    printf("Enter your choice: ");
    scanf("%d",&choice);

    switch(choice)
    {

    case 1:   // FIFO
    {
        int frame[10], front=0, faults=0, found;

        for(int i=0;i<frames;i++)
            frame[i] = -1;

        for(int i=0;i<n;i++)
        {
            found=0;

            for(int j=0;j<frames;j++)
            {
                if(frame[j]==ref[i])
                {
                    found=1;
                    break;
                }
            }

            if(!found)
            {
                frame[front] = ref[i];
                front = (front+1)%frames;
                faults++;
            }
        }

        printf("\nFIFO Page Faults = %d",faults);
        break;
    }

    case 2:   // LRU
    {
        int frame[10], time[10];
        int faults=0,counter=0,found;

        for(int i=0;i<frames;i++)
        {
            frame[i]=-1;
            time[i]=0;
        }

        for(int i=0;i<n;i++)
        {
            found=0;

            for(int j=0;j<frames;j++)
            {
                if(frame[j]==ref[i])
                {
                    counter++;
                    time[j]=counter;
                    found=1;
                    break;
                }
            }

            if(!found)
            {
                int min=0;

                for(int j=1;j<frames;j++)
                {
                    if(time[j]<time[min])
                        min=j;
                }

                frame[min]=ref[i];
                counter++;
                time[min]=counter;
                faults++;
            }
        }

        printf("\nLRU Page Faults = %d",faults);
        break;
    }

    case 3:   // Optimal
    {
        int frame[10], faults=0,found;

        for(int i=0;i<frames;i++)
            frame[i]=-1;

        for(int i=0;i<n;i++)
        {
            found=0;

            for(int j=0;j<frames;j++)
            {
                if(frame[j]==ref[i])
                {
                    found=1;
                    break;
                }
            }

            if(!found)
            {
                int pos=-1,farthest=i;

                for(int j=0;j<frames;j++)
                {
                    int k;
                    for(k=i+1;k<n;k++)
                    {
                        if(frame[j]==ref[k])
                            break;
                    }

                    if(k>farthest)
                    {
                        farthest=k;
                        pos=j;
                    }

                    if(k==n)
                    {
                        pos=j;
                        break;
                    }
                }

                if(pos==-1)
                    pos=0;

                frame[pos]=ref[i];
                faults++;
            }
        }

        printf("\nOptimal Page Faults = %d",faults);
        break;
    }

    default:
        printf("Invalid choice");
    }

    return 0;
}