#include<stdio.h>

int main() {

    int n,i,choice;
    int pid[20],at[20],bt[20],pr[20];
    float avg_wt_algo[5]={0};
    int done[5]={0};

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++){
        pid[i]=i+1;
        printf("\nP%d Arrival Time: ",pid[i]);
        scanf("%d",&at[i]);

        printf("P%d Burst Time: ",pid[i]);
        scanf("%d",&bt[i]);

        printf("P%d Priority: ",pid[i]);
        scanf("%d",&pr[i]);
    }

    while(1){

        printf("\n\n===== MENU =====");
        printf("\n1. FCFS");
        printf("\n2. SJF (Non-Preemptive)");
        printf("\n3. Priority (Non-Preemptive)");
        printf("\n4. Round Robin");
        printf("\n5. Exit");
        printf("\nEnter choice: ");
        scanf("%d",&choice);

        if(choice==5)
            break;

        int wt[20]={0},tat[20]={0},ct[20]={0},rt[20];
        float avg_wt=0,avg_tat=0;
        int time=0;

        for(i=0;i<n;i++)
            rt[i]=bt[i];

        switch(choice){

        // ================= FCFS =================
        case 1:
            for(i=0;i<n;i++){
                if(time<at[i])
                    time=at[i];

                time+=bt[i];
                ct[i]=time;
                tat[i]=ct[i]-at[i];
                wt[i]=tat[i]-bt[i];

                avg_wt+=wt[i];
                avg_tat+=tat[i];
            }

            printf("\n--- FCFS Result ---\n");
            break;

        // ================= SJF =================
        case 2:{
            int completed[20]={0},count=0;
            time=0;

            while(count<n){
                int min=9999,pos=-1;
                for(i=0;i<n;i++){
                    if(at[i]<=time && completed[i]==0){
                        if(bt[i]<min){
                            min=bt[i];
                            pos=i;
                        }
                    }
                }

                if(pos==-1)
                    time++;
                else{
                    time+=bt[pos];
                    ct[pos]=time;
                    tat[pos]=ct[pos]-at[pos];
                    wt[pos]=tat[pos]-bt[pos];

                    avg_wt+=wt[pos];
                    avg_tat+=tat[pos];

                    completed[pos]=1;
                    count++;
                }
            }

            printf("\n--- SJF Result ---\n");
            break;
        }

        // ================= Priority =================
        case 3:{
            int completed[20]={0},count=0;
            time=0;

            while(count<n){
                int high=9999,pos=-1;
                for(i=0;i<n;i++){
                    if(at[i]<=time && completed[i]==0){
                        if(pr[i]<high){   // smaller number = higher priority
                            high=pr[i];
                            pos=i;
                        }
                    }
                }

                if(pos==-1)
                    time++;
                else{
                    time+=bt[pos];
                    ct[pos]=time;
                    tat[pos]=ct[pos]-at[pos];
                    wt[pos]=tat[pos]-bt[pos];

                    avg_wt+=wt[pos];
                    avg_tat+=tat[pos];

                    completed[pos]=1;
                    count++;
                }
            }

            printf("\n--- Priority Result ---\n");
            break;
        }

        // ================= Round Robin =================
        case 4:{
            int quantum,remain=n;
            printf("Enter Time Quantum: ");
            scanf("%d",&quantum);

            time=0;

            while(remain!=0){
                for(i=0;i<n;i++){
                    if(rt[i]>0 && at[i]<=time){
                        if(rt[i]>quantum){
                            time+=quantum;
                            rt[i]-=quantum;
                        }
                        else{
                            time+=rt[i];
                            ct[i]=time;
                            tat[i]=ct[i]-at[i];
                            wt[i]=tat[i]-bt[i];

                            avg_wt+=wt[i];
                            avg_tat+=tat[i];

                            rt[i]=0;
                            remain--;
                        }
                    }
                }
            }

            printf("\n--- Round Robin Result ---\n");
            break;
        }

        default:
            printf("Invalid Choice\n");
            continue;
        }

        // ===== Common Output Section =====
        avg_wt/=n;
        avg_tat/=n;

        printf("\nPID\tAT\tBT\tCT\tWT\tTAT\n");
        for(i=0;i<n;i++){
            printf("P%d\t%d\t%d\t%d\t%d\t%d\n",
                   pid[i],at[i],bt[i],ct[i],wt[i],tat[i]);
        }

        printf("\nAverage Waiting Time = %.2f",avg_wt);
        printf("\nAverage Turnaround Time = %.2f\n",avg_tat);

        avg_wt_algo[choice]=avg_wt;
        done[choice]=1;
    }

    // ===== Minimum Comparison =====
    if(done[1] && done[2] && done[3] && done[4]){

        float min=avg_wt_algo[1];
        int best=1;

        for(i=2;i<=4;i++){
            if(avg_wt_algo[i]<min){
                min=avg_wt_algo[i];
                best=i;
            }
        }

        printf("\n===== FINAL COMPARISON =====");
        printf("\nMinimum Average Waiting Time = %.2f\n",min);

        if(best==1) printf("Best Algorithm: FCFS\n");
        if(best==2) printf("Best Algorithm: SJF\n");
        if(best==3) printf("Best Algorithm: Priority\n");
        if(best==4) printf("Best Algorithm: Round Robin\n");
    }
    else{
        printf("\nRun all 4 algorithms to see minimum comparison.\n");
    }

    return 0;
}