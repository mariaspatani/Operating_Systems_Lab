#include<stdio.h>

#define MAX 50

// Sorting
void sort(int arr[], int n){
    for(int i=0;i<n-1;i++){
        for(int j=0;j<n-i-1;j++){
            if(arr[j] > arr[j+1]){
                int t = arr[j];
                arr[j] = arr[j+1];
                arr[j+1] = t;
            }
        }
    }
}

// Graph display
void graph(int start, int seq[], int n){
    int cur = start;

    printf("\nDisk Arm Movement Path:\n");
    printf("Step | Movement\n");
    printf("--------------------------------------\n");

    for(int i=0;i<n;i++){
        printf("%2d   | (%3d) -----> [%3d]\n", i+1, cur, seq[i]);
        cur = seq[i];
    }

    printf("--------------------------------------\n");
}

// SSTF
void SSTF(int req[], int n, int head){
    int visited[MAX]={0}, seek=0;
    int seq[MAX], k=0;
    int start = head;

    for(int i=0;i<n;i++){
        int min=9999, index=-1;

        for(int j=0;j<n;j++){
            if(!visited[j]){
                int diff = head - req[j];
                if(diff < 0) diff = -diff;

                if(diff < min){
                    min = diff;
                    index = j;
                }
            }
        }

        seek += min;
        head = req[index];
        seq[k++] = head;
        visited[index]=1;
    }

    printf("\n--- SSTF ---\n");
    printf("Seek Time = %d\n", seek);
    graph(start, seq, k);
}

// LOOK
void LOOK(int req[], int n, int head){
    int seek=0, pos=0;
    int seq[MAX], k=0;
    int start = head;

    sort(req,n);

    for(int i=0;i<n;i++){
        if(req[i] >= head){
            pos = i;
            break;
        }
    }

    // Right side
    for(int i=pos;i<n;i++){
        int diff = head - req[i];
        if(diff < 0) diff = -diff;

        seek += diff;
        head = req[i];
        seq[k++] = head;
    }

    // Left side
    for(int i=pos-1;i>=0;i--){
        int diff = head - req[i];
        if(diff < 0) diff = -diff;

        seek += diff;
        head = req[i];
        seq[k++] = head;
    }

    printf("\n--- LOOK ---\n");
    printf("Seek Time = %d\n", seek);
    graph(start, seq, k);
}

// C-SCAN
void CSCAN(int req[], int n, int head, int size){
    int seek=0, pos=0;
    int seq[MAX], k=0;
    int start = head;

    sort(req,n);

    for(int i=0;i<n;i++){
        if(req[i] >= head){
            pos = i;
            break;
        }
    }

    // Right side
    for(int i=pos;i<n;i++){
        int diff = head - req[i];
        if(diff < 0) diff = -diff;

        seek += diff;
        head = req[i];
        seq[k++] = head;
    }

    // Move to end (size-1)
    int diff = head - (size - 1);
    if(diff < 0) diff = -diff;
    seek += diff;
    head = size - 1;
    seq[k++] = head;

    // Jump to 0
    seek += (size - 1);
    head = 0;
    seq[k++] = head;

    // Left side
    for(int i=0;i<pos;i++){
        int d = head - req[i];
        if(d < 0) d = -d;

        seek += d;
        head = req[i];
        seq[k++] = head;
    }

    printf("\n--- C-SCAN ---\n");
    printf("Seek Time = %d\n", seek);
    graph(start, seq, k);
}

// MAIN
int main(){
    int n, head, size, choice;
    int req[MAX];

    printf("Enter number of requests: ");
    scanf("%d",&n);

    printf("Enter requests:\n");
    for(int i=0;i<n;i++){
        scanf("%d",&req[i]);
    }

    printf("Enter initial head position: ");
    scanf("%d",&head);

    printf("Enter disk size: ");
    scanf("%d",&size);

    do{
        printf("\n1.SSTF\n2.LOOK\n3.C-SCAN\n4.Exit\n");
        printf("Enter choice: ");
        scanf("%d",&choice);

        switch(choice){
            case 1: SSTF(req,n,head); break;
            case 2: LOOK(req,n,head); break;
            case 3: CSCAN(req,n,head,size); break;
            case 4: printf("Exit\n"); break;
            default: printf("Invalid choice\n");
        }

    }while(choice!=4);

    return 0;
}
